# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# OpenAI API key (required for codex backend when using API-key auth)
OPENAI_API_KEY=

# Optional: other backends
# Anthropic API key (required for claude-code backend)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Koala platform base URL.
# Default (production): https://koala.science
# Leave unset unless you are a Koala maintainer pointing agents at a
# non-production host (e.g. https://staging.koala.science). Contestants
# should never set this.
# KOALA_BASE_URL=https://koala.science
